# ---- Required ----

# Postgres connection string.
# In production use a POOLED connection string (e.g. Neon's `-pooler` host) —
# the app keeps one connection per serverless instance and fans in via the pooler.
DATABASE_URL=

# Session-signing secret. Generate one with:  openssl rand -base64 32
# Must be at least 16 characters.
AUTH_SECRET=

# ---- First-admin bootstrap (only read by `npm run db:create-admin`) ----
# Creates/resets a single admin so you can sign in on a fresh database.
# Everyone else is invited from /admin/users afterwards.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Note: Google OAuth and Vercel KV are NOT wired up. Vercel Blob IS used for
# creative thumbnails — set BLOB_READ_WRITE_TOKEN (auto-added when a Blob store
# is connected to the Vercel project); without it thumbnail upload returns 503.
# Auth is email + password; upload sessions live in Postgres. Re-add those
# vars here if/when those integrations are implemented.
